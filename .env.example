# Public site URL (no trailing slash) — set after first Vercel deploy
# Example: https://dilber-ozer.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Formspree form ID — create a free form at https://formspree.io
# Your endpoint looks like: https://formspree.io/f/abcdwxyz
# Use only the ID part here: abcdwxyz
FORMSPREE_FORM_ID=

# Set to true for unlisted/private-style deploy (blocks search engines)
SITE_PRIVATE=false
