# Ollama (open-source LLM runtime)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# Knowledge directory (relative to repo root or absolute path)
KNOWLEDGE_DIR=../knowledge

# CORS — Next.js dev / production origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Phase 2 — faster-whisper
# WHISPER_MODEL=large-v3
# WHISPER_DEVICE=cuda

# Phase 2 — Piper TTS
# PIPER_MODEL_PATH=./models/piper/tr_TR-dfki-medium.onnx

# Phase 3 — PostgreSQL + pgvector
# DATABASE_URL=postgresql://user:pass@localhost:5432/twin
